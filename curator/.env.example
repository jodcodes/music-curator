# affective_playlists - Environment Configuration
# 
# This file contains all environment variables required by the affective_playlists subprojects:
# - 4tempers: AI-based playlist temperament analysis
# - metad_enr: Metadata filling and enrichment
# - plsort: Playlist organization and classification
#
# Copy this file to .env and fill in your credentials
# IMPORTANT: Never commit .env file with real credentials!

# ============================================================================
# 4TEMPERS - AI-Based Playlist Temperament Analysis
# ============================================================================

# OpenAI API Configuration (REQUIRED for 4tempers)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Spotify API Configuration (OPTIONAL - for enriched track metadata)
# Get these at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# ============================================================================
# METAD_ENR - Metadata Filling and Enrichment
# ============================================================================

# Last.fm API Configuration (OPTIONAL - for additional metadata)
# Get your key at: https://www.last.fm/api/account/create
LASTFM_API_KEY=your-lastfm-api-key

# MusicBrainz Configuration (uses free API - no key required)
# But you can provide user-agent for better rate limiting
MUSICBRAINZ_USER_AGENT=affective_playlists/1.0

# Discogs API Configuration (OPTIONAL - for additional metadata)
# Get your token at: https://www.discogs.com/settings/developers
# Register as an application to get a token
DISCOGS_TOKEN=your-discogs-token

# ============================================================================
# PLSORT - Playlist Organization and Classification
# ============================================================================

# Playlist whitelist filtering (OPTIONAL)
# If set to "true", only processes whitelisted playlists
USE_PLAYLIST_WHITELIST=true

# ============================================================================
# SHARED CONFIGURATION
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# CENTRALIZED WHITELIST CONFIGURATION
# ============================================================================
#
# All subrepos (4tempers, metad_enr, plsort) now use a centralized whitelist:
#   File: whitelist.json (at project root)
#   
# To enable whitelisting:
#   1. Edit whitelist.json
#   2. Set "enabled": true
#   3. Customize the "playlists" array
#
# Format:
#   {
#     "enabled": false,
#     "description": "Global whitelist for all subrepos",
#     "playlists": [
#       "Playlist Name 1",
#       "Playlist Name 2"
#     ]
#   }
#
# When whitelist is DISABLED (enabled=false):
#   - All subrepos process all available playlists
#   - Whitelist configuration is ignored
#
# When whitelist is ENABLED (enabled=true):
#   - All subrepos only process whitelisted playlists
#   - Must match playlist names exactly (case-sensitive)
#
# ============================================================================

# Cache directory for web enrichment queries
CACHE_DIR=./cache

# Cache TTL in seconds (default: 604800 = 7 days)
CACHE_TTL=604800

# Enable verbose logging (defaults to false if not set)
VERBOSE=false
