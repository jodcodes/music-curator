#!/usr/bin/env python3
"""
End-to-End Test Suite for plMetaTemp

Tests for:
1. 4tempers - AI temperament analysis
2. metad_enr - Metadata enrichment
3. plsort - Playlist organization
"""

import json
import os
import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).parent
sys.path.insert(0, str(PROJECT_ROOT))

# Colors
GREEN = '\033[0;32m'
RED = '\033[0;31m'
BLUE = '\033[0;34m'
NC = '\033[0m'


def print_test(name, passed, error=""):
    """Print test result."""
    status = f"{GREEN}✓{NC}" if passed else f"{RED}✗{NC}"
    print(f"  {status} {name}")
    if error:
        print(f"    {RED}Error: {error}{NC}")


def print_section(title):
    """Print section header."""
    print(f"\n{BLUE}{'='*70}")
    print(f"➜ {title}")
    print(f"{'='*70}{NC}\n")


class TestResult:
    """Track test results."""
    def __init__(self):
        self.total = 0
        self.passed = 0
        self.failed = 0
        self.errors = []
    
    def add(self, name, passed, error=""):
        self.total += 1
        if passed:
            self.passed += 1
        else:
            self.failed += 1
            self.errors.append((name, error))
        print_test(name, passed, error)
    
    def summary(self):
        print(f"\n{BLUE}{'='*70}{NC}")
        print(f"Total: {self.total} | {GREEN}Passed: {self.passed}{NC} | {RED}Failed: {self.failed}{NC}")
        print(f"{BLUE}{'='*70}{NC}")
        return self.failed == 0


def test_shared_modules():
    """Test shared modules."""
    print_section("Testing Shared Modules")
    results = TestResult()
    
    try:
        from shared.apple_music import AppleMusicInterface
        results.add("Import AppleMusicInterface", True)
    except Exception as e:
        results.add("Import AppleMusicInterface", False, str(e))
    
    try:
        from shared.normalizer import TextNormalizer
        results.add("Import TextNormalizer", True)
    except Exception as e:
        results.add("Import TextNormalizer", False, str(e))
    
    try:
        from shared.logger import setup_logger
        results.add("Import setup_logger", True)
    except Exception as e:
        results.add("Import setup_logger", False, str(e))
    
    # Test TextNormalizer functionality
    try:
        from shared.normalizer import TextNormalizer
        normalizer = TextNormalizer()
        result = normalizer.normalize("  HELLO & World!  ")
        passed = result == "hello and world"
        results.add("TextNormalizer.normalize()", passed, f"Got: {result}")
    except Exception as e:
        results.add("TextNormalizer.normalize()", False, str(e))
    
    assert results.summary(), f"Test failures: {results.errors}"


def test_4tempers():
    """Test 4tempers module."""
    print_section("Testing 4tempers - AI Temperament Analysis")
    results = TestResult()
    
    try:
        sys.path.insert(0, str(PROJECT_ROOT / '4tempers'))
        # Try to import core modules
        results.add("4tempers module structure exists", True)
    except Exception as e:
        results.add("4tempers module structure exists", False, str(e))
    
    # Check config file
    config_path = PROJECT_ROOT / '4tempers' / 'config.json'
    try:
        if config_path.exists():
            with open(config_path, 'r') as f:
                config = json.load(f)
            results.add("4tempers config.json loads", True)
            results.add("4tempers has API keys config", 'api_keys' in config)
        else:
            results.add("4tempers config.json exists", False, "File not found")
    except Exception as e:
        results.add("4tempers config.json loads", False, str(e))
    
    assert results.summary(), f"Test failures: {results.errors}"


