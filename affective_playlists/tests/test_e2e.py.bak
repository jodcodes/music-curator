def test_cli():
    """Test main CLI."""
    print_section("Testing Main CLI")
    results = TestResult()
    
    import subprocess

    # Test --help
    try:
        result = subprocess.run(
            [sys.executable, str(PROJECT_ROOT / 'main.py'), '--help'],
            capture_output=True,
            text=True,
            timeout=5
        )
        results.add("main.py --help", result.returncode == 0)
    except Exception as e:
        results.add("main.py --help", False, str(e))
    
    # Test --list
    try:
        result = subprocess.run(
            [sys.executable, str(PROJECT_ROOT / 'main.py'), '--list'],
            capture_output=True,
            text=True,
            timeout=5
        )
        passed = result.returncode == 0 and '4tempers' in result.stdout
        results.add("main.py --list", passed)
    except Exception as e:
        results.add("main.py --list", False, str(e))
    
    assert results.summary(), f"Test failures: {results.errors}"


def test_configuration():
    """Test configuration files."""
    print_section("Testing Configuration Files")
    results = TestResult()
    
    config_files = [
        ('4tempers/config.json', '4tempers'),
        ('metad_enr/config.json', 'metad_enr'),
        ('plsort/config.json', 'plsort'),
    ]
    
    for file_path, name in config_files:
        full_path = PROJECT_ROOT / file_path
        try:
            if full_path.exists():
                with open(full_path, 'r') as f:
                    config = json.load(f)
                results.add(f"{name} config.json is valid", True)
            else:
                results.add(f"{name} config.json exists", False, "File not found")
        except Exception as e:
            results.add(f"{name} config.json is valid", False, str(e))
    
    # Test centralized whitelist file
    whitelist_path = PROJECT_ROOT / 'whitelist.json'
    try:
        if whitelist_path.exists():
            with open(whitelist_path, 'r') as f:
                whitelist = json.load(f)
            has_enabled = 'enabled' in whitelist
            has_playlists = 'playlists' in whitelist
            playlist_count = len(whitelist.get('playlists', []))
            results.add(f"Centralized whitelist.json is valid", has_enabled and has_playlists)
            results.add(f"Whitelist has {playlist_count} playlists", playlist_count > 0)
        else:
            results.add(f"Centralized whitelist.json exists", False, "File not found")
    except Exception as e:
        results.add(f"Centralized whitelist.json is valid", False, str(e))
    
    assert results.summary(), f"Test failures: {results.errors}"


