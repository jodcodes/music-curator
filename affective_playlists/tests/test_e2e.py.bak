def main():
    """Run all tests."""
    print(f"{BLUE}")
    print("╔" + "═"*68 + "╗")
    print("║" + " "*68 + "║")
    print("║" + "  plMetaTemp - End-to-End Test Suite".center(68) + "║")
    print("║" + "  Testing all three subprojects".center(68) + "║")
    print("║" + " "*68 + "║")
    print("╚" + "═"*68 + "╝")
    print(f"{NC}")
    
    # Run all tests
    results = []
    results.append(("Shared Modules", test_shared_modules()))
    results.append(("4tempers", test_4tempers()))
    results.append(("metad_enr", test_metad_enr()))
    results.append(("plsort", test_plsort()))
    results.append(("Configuration", test_configuration()))
    results.append(("Shared Imports", test_imports_from_shared()))
    results.append(("CLI", test_cli()))
    
    # Summary
    print_section("Test Summary")
    all_passed = True
    for name, passed in results:
        status = f"{GREEN}PASS{NC}" if passed else f"{RED}FAIL{NC}"
        print(f"  {status} - {name}")
        all_passed = all_passed and passed
    
    print()
    if all_passed:
        print(f"{GREEN}✓ All tests passed! plMetaTemp is ready to use.{NC}\n")
        return 0
    else:
        print(f"{RED}✗ Some tests failed. Please review errors above.{NC}\n")
        return 1


if __name__ == '__main__':
    sys.exit(main())
