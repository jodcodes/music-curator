# Spotify API Configuration
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Optional: Custom redirect URI (default: http://localhost:8888/callback)
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Optional: Custom scope (default: playlist-modify-public playlist-modify-private)
SPOTIFY_SCOPE=playlist-modify-public playlist-modify-private

# Apple Music Configuration
# Path to your AppleScript file
APPLE_SCRIPT_PATH=./get_playlist.scpt

# Logging Configuration
# Optional: Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Sync behaviour
# Skip playlists that were successfully synced fewer than this many days ago
# AND whose track count hasn't changed.  Set to 0 to always sync every playlist.
STALE_SYNC_DAYS=7

# Rate-limit handling: if Spotify asks us to wait longer than this many seconds
# the script saves its progress and exits so you can resume later with another run.
# Default is 0 (always save-and-exit) since Spotify quota resets are typically 24h.
RATE_LIMIT_MAX_WAIT=0
